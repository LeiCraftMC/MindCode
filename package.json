{
    "name": "leios-hub-website",
    "type": "module",
    "private": true,
    "scripts": {
        "db:generate": "bun scripts/db-utils && bunx --bun drizzle-kit generate --config=drizzle.config.ts",
        "db:migrate": "bun scripts/db-utils && bunx --bun drizzle-kit migrate --config=drizzle.config.ts",
        "build": "nuxt build",
        "start": "bun run .output/server/index.mjs --port 13338",
        "dev": "nuxt dev --port 13338",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "api-client:generate": "openapi-ts && bun scripts/patch-api-client.ts",
        "typecheck": "nuxt typecheck && tsc -p ./tsconfig/tsconfig.typecheck.json && echo 'Typecheck passed!'",
        "test": "bun test"
    },
    "dependencies": {
        "@hey-api/nuxt": "^0.2.1",
        "@hey-api/openapi-ts": "^0.98.2",
        "@libsql/client": "^0.17.4",
        "@nuxt/ui": "^4.8.2",
        "@scalar/hono-api-reference": "^0.11.5",
        "bun-types": "^1.3.14",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "hono": "^4.12.26",
        "hono-openapi": "^1.3.0",
        "nuxt": "^4.4.8",
        "typescript": "^6.0.3",
        "vue": "^3.5.35",
        "vue-router": "^5.1.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@iconify-json/lucide": "^1.2.111",
        "@types/bun": "^1.3.14",
        "vue-tsc": "^3.3.5"
    }
}
