MINDCODE_LOG_LEVEL=info

MINDCODE_HOST=::
MINDCODE_PORT=13338
MINDCODE_API_DISABLE_DOCS=false

MINDCODE_DB_PATH=./data/db.sqlite
MINDCODE_DB_AUTO_MIGRATE=true

MINDCODE_CONFIG_BASE_DIR=./config

MINDCODE_APP_URL=http://localhost:13338

